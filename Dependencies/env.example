SMA_CROSSOVER_SHORT_WINDOW=9
SMA_CROSSOVER_LONG_WINDOW=21
SMA_CROSSOVER_STOP_LOSS_PCT=0.015
SMA_CROSSOVER_TARGET_PCT=0.03

